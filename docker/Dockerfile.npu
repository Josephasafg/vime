ARG BASE_IMAGE=registry-cbu.huawei.com/atelier/verl:verl_0.8.0-vllm_0.17.0-mindspeed_0.16.0-pytorch_2.9.0-cann_8.5.2-py_3.11-hce_2.0.2512-aarch64-snt9b-20260513174224-90d255f
FROM ${BASE_IMAGE}

ARG PATCH_VERSION=latest
# sgl-kernel-npu commit bundled in verl v22 base image (2026.6.0).
ARG SGL_KERNEL_NPU_COMMIT=87df718a2f15161d3120e4e1dfd19b30afca7cbf
ARG SGL_KERNEL_NPU_REPO=https://github.com/sgl-project/sgl-kernel-npu.git

WORKDIR /home/ma-user

# torch_memory_saver (NPU): hook aclrtMalloc for PyTorch CachingAllocator + install preload .so
COPY docker/patch/${PATCH_VERSION}/torch-memory-saver-npu.patch /tmp/torch-memory-saver-npu.patch
RUN SGL_DIR=/home/ma-user/sgl-kernel-npu && \
    if [ -d "${SGL_DIR}/.git" ] && [ -f "${SGL_DIR}/build.sh" ]; then \
        echo ">>> Using sgl-kernel-npu from base image"; \
        cd "${SGL_DIR}" && git checkout "${SGL_KERNEL_NPU_COMMIT}"; \
    else \
        echo ">>> sgl-kernel-npu not found in base image, cloning from ${SGL_KERNEL_NPU_REPO}"; \
        rm -rf "${SGL_DIR}" && \
        git clone "${SGL_KERNEL_NPU_REPO}" "${SGL_DIR}" && \
        cd "${SGL_DIR}" && git checkout "${SGL_KERNEL_NPU_COMMIT}"; \
    fi && \
    patch -p1 -f --no-backup-if-mismatch < /tmp/torch-memory-saver-npu.patch && \
    bash build.sh -a memory-saver && \
    pip install output/torch_memory_saver-*.whl --no-deps --force-reinstall && \
    TMS_PKG="$(python3 -c 'import torch_memory_saver, os; print(os.path.dirname(torch_memory_saver.__file__))')" && \
    PRELOAD_SO="$(find contrib/torch_memory_saver/python/build -name 'torch_memory_saver_hook_mode_preload*.abi3.so' | head -1)" && \
    test -n "${PRELOAD_SO}" && cp "${PRELOAD_SO}" "${TMS_PKG}/"

COPY docker/patch/${PATCH_VERSION}/megatron-all-changes.patch /tmp/megatron-all-changes.patch
RUN cd Megatron-LM && \
    patch -p1 -f --no-backup-if-mismatch < /tmp/megatron-all-changes.patch || true && \
    pip install -e . --no-build-isolation --no-deps

COPY docker/patch/${PATCH_VERSION}/vllm.patch /tmp/vllm.patch
RUN cd vllm && \
    patch -p1 -f --no-backup-if-mismatch < /tmp/vllm.patch || true

COPY docker/patch/${PATCH_VERSION}/vllm-ascend.patch /tmp/vllm-ascend.patch
RUN cd vllm-ascend && \
    patch -p1 -f --no-backup-if-mismatch < /tmp/vllm-ascend.patch || true

COPY docker/patch/${PATCH_VERSION}/mindspeed.patch /tmp/mindspeed.patch
RUN cd MindSpeed && \
    patch -p1 -f --no-backup-if-mismatch < /tmp/mindspeed.patch || true

COPY docker/patch/${PATCH_VERSION}/torch_npu.patch /tmp/torch_npu.patch
RUN TORCH_NPU_DIR=$(python3 -c "import importlib.util; print(importlib.util.find_spec('torch_npu').submodule_search_locations[0])") && \
    cd ${TORCH_NPU_DIR} && \
    patch -p2 < /tmp/torch_npu.patch || echo "torch_npu patch skipped (version mismatch)"

COPY . /home/ma-user/vime/
RUN git config --global --add safe.directory /home/ma-user/vime && \
    cd /home/ma-user/vime && \
    pip install -e . --no-deps --no-build-isolation

ENV PYTHONPATH=/home/ma-user/Megatron-LM:/home/ma-user/vllm:/home/ma-user/vime:${PYTHONPATH}
ENV CUDA_DEVICE_MAX_CONNECTIONS=1

ENTRYPOINT []
CMD ["/bin/bash"]
